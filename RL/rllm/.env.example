# Copy this file to `.env` and fill in the secrets; the launch scripts in
# vision_deepresearch_async_workflow/run/ auto-load it via `source .env`.
#
# All values are optional — the training loop will run without them, but
# search tools and the LLM-judge reward will degrade to no-op / 0.0.

# ---------------------------------------------------------------------------
# Weights & Biases
# ---------------------------------------------------------------------------
export WANDB_BASE_URL=https://api.wandb.ai
export WANDB_API_KEY=""

# ---------------------------------------------------------------------------
# External search providers (direct)
# ---------------------------------------------------------------------------
export SERP_API_KEY=""          # https://serper.dev
export JINA_API_KEY=""          # https://jina.ai
export ZHIPU_API_KEY=""         # optional image-search provider

# ---------------------------------------------------------------------------
# Optional proxy gateway that fronts Serper / Jina behind a single HMAC key.
# Leave empty to call providers directly with the keys above.
# ---------------------------------------------------------------------------
export API_GATEWAY_HOST=""
export API_GATEWAY_USER=""
export API_GATEWAY_KEY=""

# ---------------------------------------------------------------------------
# Layout parsing endpoint (PP-StructureV3 compatible)
# ---------------------------------------------------------------------------
export LAYOUT_PARSING_API_URL=""
export LAYOUT_PARSING_TOKEN=""

# ---------------------------------------------------------------------------
# OpenAI-compatible LLM judge used by the query-utility reward
# ---------------------------------------------------------------------------
export JUDGE_API_BASE_URL="https://api.openai.com/v1"
export JUDGE_API_KEY=""
export JUDGE_MODEL="gpt-4o"

# ---------------------------------------------------------------------------
# Optional COS uploader (for image_search with local images)
# ---------------------------------------------------------------------------
export COS_USERID="opensearch-vl"
export COS_UPLOAD_PATHS=""

# ---------------------------------------------------------------------------
# NCCL / RDMA tuning — adjust for your cluster. The defaults below assume a
# NIC-bonded fabric (bond1) with Mellanox ConnectX cards. If you don't have
# RDMA, set NCCL_IB_DISABLE=1 and remove the IB-specific knobs.
# ---------------------------------------------------------------------------
export NCCL_IB_GID_INDEX=3
export NCCL_IB_SL=3
export NCCL_IB_DISABLE=0
export NCCL_IB_QPS_PER_CONNECTION=4
export NCCL_NET_GDR_LEVEL=2
export NCCL_IB_TC=160
export NCCL_PXN_DISABLE=1
export NCCL_COLLNET_ENABLE=0
export NCCL_P2P_DISABLE=0
export NCCL_CHECK_DISABLE=1
export NCCL_LL_THRESHOLD=16384
export NCCL_IB_CUDA_SUPPORT=1
export SHARP_COLL_ENABLE_SAT=0
export TOKENIZERS_PARALLELISM=false

export NCCL_SOCKET_IFNAME=bond1
export GLOO_SOCKET_IFNAME=bond1
export UCX_NET_DEVICES=bond1
# export NCCL_IB_HCA=mlx5_bond_1,mlx5_bond_2,mlx5_bond_3,mlx5_bond_4

# Container environments that share hostnames between nodes must give each
# Ray worker a unique NCCL host id before `ray start`:
export NCCL_HOSTID=$(hostname -I | awk '{print $1}')
echo "[.env] NCCL_HOSTID=${NCCL_HOSTID}  hostname=$(hostname)"
